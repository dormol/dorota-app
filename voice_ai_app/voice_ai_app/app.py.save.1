mport time

def choose_audio():
    print("\nWybierz dźwięk tła:")
    print("1 - Silence")
    print("2 - Nature sounds")
    print("3 - Focus ambient")

    choice = input("Twój wybór: ")

    if choice == "2":
        return "Nature sounds"
    elif choice == "3":
        return "Focus ambient"
    else:
        return "Silence"


def choose_mode():
    print("\nWybierz rozgrzewkę:")
    print("1 - Sketch")
    print("2 - Color")

    choice = input("Twój wybór: ")

    if choice == "2":
        return "color"
    return "sketch"


def instruction(mode):
    if mode == "color":
        return "Zmieszaj 3 kolory: ciepły, chłodny, neutralny. Skup się na value."
    else:
        return "Narysuj szybki szkic. Bez korekty."


def run_timer(minutes):
    seconds = minutes * 60
    print("\nStart. Pracuj.")

    while seconds > 0:
        time.sleep(1)
        seconds -= 1

    print("\nSTOP.")


def main():
    print("\n=== DAILY WARM-UP v1 ===")
    print("Nie oceniaj. Tylko działaj.\n")

    audio = choose_audio()
    mode = choose_mode()

    print("\nAudio:", audio)
    print("Tryb:", mode)
    print("\nInstrukcja:")
    print(instruction(mode))

    input("\nENTER aby start")

    run_timer(10)

    print("\nRozgrzewka zakończona.")


main()

